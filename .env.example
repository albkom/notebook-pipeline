# Paths are relative to the container's WORKDIR (/app)
DATA_DIR=/app/data
INPUT_DIR=/app/data/input
OUTPUT_DIR=/app/data/output

# Email (used by notebooks/send_email_report.ipynb)
# Mailhog defaults (local dev) — web UI at http://localhost:8025
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=pipeline@example.com
EMAIL_TO=recipient@example.com  # comma-separated for multiple recipients
